# Use NVIDIA CUDA base image
FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Install system dependencies
RUN apt-get update && \
    apt-get install -y \
        python3-pip \
        python3-dev \
        python3-venv \
        git \
        ffmpeg \
        build-essential \
        pkg-config \
        curl \
        wget \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

# Install uv
RUN curl -LsSf https://astral.sh/uv/0.7.12/install.sh | sh && \
    cp /root/.local/bin/uv /usr/local/bin/uv && \
    cp /root/.local/bin/uvx /usr/local/bin/uvx

# Install core dependencies first
RUN uv pip install --system --no-cache-dir \
    "numpy==2.1.3" \
    scipy \
    typing-extensions \
    packaging

# Install PyTorch with CUDA support (BEFORE other requirements)
RUN uv pip install --system --no-cache-dir \
    torch \
    torchaudio \
    --index-url https://download.pytorch.org/whl/cu124

# Install other basic packages
RUN uv pip install --system --no-cache-dir \
    fastapi \
    "uvicorn[standard]" \
    python-multipart \
    aiofiles==24.1.0 \
    pydub

# Install Whisper from git (as specified in your requirements)
RUN uv pip install --system --no-cache-dir \
   "git+https://github.com/openai/whisper.git@517a43ecd132a2089d85f4ebc044728a71d49f6e"

# Install faster-whisper (as specified in requirements)
RUN uv pip install --system --no-cache-dir faster-whisper


# Copy application
COPY ./whisper_ext/whisper_transcribe.py .

# Set environment variables for NVIDIA
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Test that everything works
RUN python3 -c "import torch; print(f'PyTorch version: {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}')"
RUN python3 -c "import whisper; print(f'Whisper loaded successfully')"

CMD ["python3", "-m", "uvicorn", "whisper_transcribe:app", "--host", "0.0.0.0", "--port", "8001", "--timeout-keep-alive", "900"]